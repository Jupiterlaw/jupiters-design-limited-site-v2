---
interface PriceRange {
  min: number;
  max: number;
}

interface Package {
  id: 'essential' | 'signature' | 'elevated';
  label: string;
  enLabel: string;
  englishLabel: string;
  description: string;
  enDescription: string;
  price: PriceRange;
  materialsIncluded: boolean;
  featured?: boolean;
}

interface FlooringType {
  label: string;
  enLabel: string;
  minimumCharge: number;
  packages: Package[];
}

interface Props {
  lang?: 'zh-HK' | 'en';
}

const { lang = 'zh-HK' } = Astro.props;
const isEn = lang === 'en';

const flooringTypes: Record<'spc' | 'outdoor', FlooringType> = {
  spc: {
    label: 'SPC 地板',
    enLabel: 'SPC Flooring',
    minimumCharge: 3000,
    packages: [
      {
        id: 'essential',
        label: '基礎之選',
        enLabel: 'Essential',
        englishLabel: 'Essential',
        description: '實用、耐用，適合預算優先的空間。',
        enDescription: 'Practical and durable, for spaces where budget leads.',
        price: { min: 16, max: 20 },
        materialsIncluded: false,
      },
      {
        id: 'signature',
        label: '推薦之選',
        enLabel: 'Signature',
        englishLabel: 'Signature',
        description: '在質感、耐用與預算之間取得平衡。',
        enDescription: 'A balance of texture, endurance and budget.',
        price: { min: 35, max: 39 },
        featured: true,
        materialsIncluded: true,
      },
      {
        id: 'elevated',
        label: '質感之選',
        enLabel: 'Elevated',
        englishLabel: 'Elevated',
        description: '為重視材料表情與完成細節的空間而設。',
        enDescription: 'For spaces that prize material expression and finishing.',
        price: { min: 48, max: 52 },
        materialsIncluded: true,
      },
    ],
  },
  outdoor: {
    label: '戶外地板',
    enLabel: 'Outdoor Flooring',
    minimumCharge: 6000,
    packages: [
      {
        id: 'essential',
        label: '基礎之選',
        enLabel: 'Essential',
        englishLabel: 'Essential',
        description: '兼顧戶外耐用度與實用預算。',
        enDescription: 'Outdoor endurance with a practical budget.',
        price: { min: 45, max: 50 },
        materialsIncluded: false,
      },
      {
        id: 'signature',
        label: '推薦之選',
        enLabel: 'Signature',
        englishLabel: 'Signature',
        description: '為露台、天台與戶外平台提供平衡方案。',
        enDescription: 'A balanced plan for terraces, roofs and outdoor platforms.',
        price: { min: 110, max: 115 },
        featured: true,
        materialsIncluded: true,
      },
      {
        id: 'elevated',
        label: '質感之選',
        enLabel: 'Elevated',
        englishLabel: 'Elevated',
        description: '為重視細節、表面質感與戶外表現的空間而設。',
        enDescription: 'For spaces that value detail, surface quality and outdoor presence.',
        price: { min: 200, max: 220 },
        materialsIncluded: true,
      },
    ],
  },
};

const calculatorConfig = {
  minArea: 50,
  maxArea: 2000,
  step: 10,
  defaultArea: 300,
  removalRate: 40,
  whatsappNumber: '85295715155',
};

// UI strings, per language
const ui = {
  'zh-HK': {
    kicker: '01 · 初步估算',
    introTitleA: '先了解一個',
    introTitleB: '大概的預算。',
    introBody: '選擇工程類型及預計面積，即時查看三個初步預算方案。最終報價會按現場基層、收口、拆除、搬運及實際工程範圍確認。',
    typeLegend: '工程類型',
    areaLabel: '預計施工面積',
    areaInputLabel: '平方呎 (sq ft)',
    areaHelper: '可用鍵盤方向鍵微調面積，每次 10 sq ft。',
    removalTitle: '需要拆除舊地板',
    removalNote: '',
    summaryType: '目前選擇',
    summaryMinimum: '最低工程費',
    packageRate: '材料與安裝全包',
    packageRateExcluded: '只含安裝',
    materialNote: '不含材料',
    packageEstimate: '初步預算範圍',
    packageCta: '選擇此方案',
    badge: '最多人選',
    noteTitle: '重要',
    noteBody: '此工具只供初步預算參考，並非正式報價。最終報價須按現場量度、基層狀況、材料選擇、收口位置、拆除安排、搬運條件及工程範圍確認。',
    waGreeting: '你好，想查詢初步地板報價。',
    waArea: '預計面積',
    waPackage: '方案',
    waRemovalYes: '需要拆除舊地板',
    waRemovalNo: '不需要拆除舊地板',
    waEstimate: '網站初步預算',
    waClosing: '請問可以安排進一步查詢或現場勘察嗎？',
  },
  en: {
    kicker: '01 · Estimate Your Project',
    introTitleA: 'A rough sense of',
    introTitleB: 'the budget, first.',
    introBody: 'Choose a project type and estimated area to see three indicative packages instantly. The final quote is confirmed on site — subfloor, edges, removal, logistics and exact scope.',
    typeLegend: 'Project type',
    areaLabel: 'Estimated area',
    areaInputLabel: 'Area (sq ft)',
    areaHelper: 'Use the arrow keys to adjust area in steps of 10 sq ft.',
    removalTitle: 'Removal of existing flooring',
    removalNote: '',
    summaryType: 'Currently selected',
    summaryMinimum: 'Minimum project fee',
    packageRate: 'Material & installation included',
    packageRateExcluded: 'Installation only',
    materialNote: 'Materials not included',
    packageEstimate: 'Indicative estimate',
    packageCta: 'Choose this package',
    badge: 'Most chosen',
    noteTitle: 'Important',
    noteBody: 'This tool is for indicative reference only, not a formal quote. The final quote is confirmed on site — measurements, subfloor condition, material choice, edge details, removal, logistics and scope.',
    waGreeting: 'Hello, I would like a preliminary flooring quote.',
    waArea: 'Estimated area',
    waPackage: 'Package',
    waRemovalYes: 'Removal of existing flooring needed',
    waRemovalNo: 'No removal needed',
    waEstimate: 'Website indicative estimate',
    waClosing: 'Could we arrange a follow-up or site visit?',
  },
};

const dictionary = isEn ? ui.en : ui['zh-HK'];
---

<section
  class="price-calculator"
  data-price-calculator
  data-pricing={JSON.stringify(flooringTypes)}
  data-config={JSON.stringify(calculatorConfig)}
  data-lang={lang}
>
  <div class="editorial-shell">
    <div class="price-calculator__intro">
      <p class="editorial-kicker">{dictionary.kicker}</p>
      <h1>
        {dictionary.introTitleA}<br />
        <em>{dictionary.introTitleB}</em>
      </h1>
      <p set:html={dictionary.introBody}></p>
    </div>

    <div class="price-calculator__controls">
      <fieldset class="calculator-fieldset">
        <legend>{dictionary.typeLegend}</legend>
        <div class="calculator-type-switch" role="radiogroup" aria-label={dictionary.typeLegend}>
          <label>
            <input type="radio" name="flooring-type" value="spc" checked />
            <span>{isEn ? flooringTypes.spc.enLabel : flooringTypes.spc.label}</span>
          </label>
          <label>
            <input type="radio" name="flooring-type" value="outdoor" />
            <span>{isEn ? flooringTypes.outdoor.enLabel : flooringTypes.outdoor.label}</span>
          </label>
        </div>
      </fieldset>

      <div class="calculator-area">
        <div class="calculator-area__heading">
          <label for="area-slider">{dictionary.areaLabel}</label>
          <output for="area-slider" data-area-output>300 <small>sq ft</small></output>
        </div>

        <input
          id="area-slider"
          class="calculator-area__slider"
          type="range"
          min={calculatorConfig.minArea}
          max={calculatorConfig.maxArea}
          step={calculatorConfig.step}
          value={calculatorConfig.defaultArea}
          aria-describedby="area-helper"
        />

        <div class="calculator-area__range" aria-hidden="true">
          <span>{calculatorConfig.minArea} sq ft</span>
          <span>{calculatorConfig.maxArea.toLocaleString()} sq ft</span>
        </div>

        <div class="calculator-area__input">
          <label for="area-input">{dictionary.areaInputLabel}</label>
          <div class="calculator-area__input-field">
            <input
              id="area-input"
              class="calculator-area__number"
              type="number"
              inputmode="numeric"
              min={calculatorConfig.minArea}
              max={calculatorConfig.maxArea}
              step={calculatorConfig.step}
              value={calculatorConfig.defaultArea}
              data-area-input
              aria-describedby="area-helper"
            />
            <span class="calculator-area__unit">sq ft</span>
          </div>
        </div>

        <p id="area-helper" class="calculator-area__helper">
          {dictionary.areaHelper}
        </p>
      </div>

      <label class="calculator-removal">
        <input type="checkbox" data-removal-toggle />
        <span class="calculator-removal__box" aria-hidden="true"></span>
        <span>
          <strong>{dictionary.removalTitle}</strong>
          <small>{dictionary.removalNote}</small>
        </span>
      </label>
    </div>

    <div class="price-calculator__summary">
      <div>
        <span>{dictionary.summaryType}</span>
        <strong data-summary-type>{isEn ? flooringTypes.spc.enLabel : flooringTypes.spc.label}</strong>
      </div>
      <div>
        <span>{dictionary.summaryMinimum}</span>
        <strong data-summary-minimum>HK$3,000</strong>
      </div>
      <div data-removal-summary hidden>
        <span>{dictionary.removalTitle}</span>
        <strong data-removal-amount>HK$0</strong>
      </div>
    </div>

    <div class="calculator-packages" data-package-list aria-live="polite">
      {flooringTypes.spc.packages.map((packageItem) => (
        <article
          class:list={['calculator-package', packageItem.featured && 'calculator-package--featured']}
          data-package={packageItem.id}
        >
          {packageItem.featured && <p class="calculator-package__badge">{dictionary.badge}</p>}

          <div class="calculator-package__top">
            <span class="calculator-package__number">
              {packageItem.id === 'essential' ? '01' : packageItem.id === 'signature' ? '02' : '03'}
            </span>
            <span class="calculator-package__english">{packageItem.englishLabel}</span>
          </div>

          <h2>{isEn ? packageItem.enLabel : packageItem.label}</h2>
          <p class="calculator-package__description">{isEn ? packageItem.enDescription : packageItem.description}</p>

          <div class="calculator-package__rate">
            <span>{packageItem.materialsIncluded ? dictionary.packageRate : dictionary.packageRateExcluded}</span>
            {!packageItem.materialsIncluded && <small>{dictionary.materialNote}</small>}
          </div>

          <div class="calculator-package__estimate">
            <span>{dictionary.packageEstimate}</span>
            <strong data-estimate>HK$4,800 – HK$6,000</strong>
          </div>

          <a
            class="calculator-package__cta"
            href={`https://wa.me/${calculatorConfig.whatsappNumber}`}
            target="_blank"
            rel="noopener noreferrer"
            data-whatsapp={packageItem.id}
          >
            {dictionary.packageCta} <span>↗</span>
          </a>
        </article>
      ))}
    </div>

    <div class="price-calculator__note">
      <span>{dictionary.noteTitle}</span>
      <p set:html={dictionary.noteBody}></p>
    </div>
  </div>
</section>

<style>
  .price-calculator {
    padding: clamp(72px, 11vw, 132px) 0;
    background: var(--paper);
    color: var(--ink);
  }

  .price-calculator__intro {
    max-width: 640px;
    margin-bottom: clamp(40px, 6vw, 64px);
  }

  .price-calculator__intro h1 {
    margin: 18px 0 20px;
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(34px, 5vw, 54px);
    line-height: 1.08;
    letter-spacing: -0.01em;
  }

  .price-calculator__intro h1 em {
    font-style: italic;
    color: var(--moss);
  }

  .price-calculator__intro p {
    margin: 0;
    max-width: 52ch;
    color: var(--ink-soft);
    font-size: 15px;
    line-height: 1.7;
  }

  .price-calculator__controls {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    gap: clamp(28px, 4vw, 56px);
    align-items: start;
    padding: clamp(28px, 4vw, 40px) 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .calculator-fieldset {
    margin: 0;
    padding: 0;
    border: 0;
  }

  .calculator-fieldset legend {
    padding: 0;
    margin-bottom: 16px;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--moss);
  }

  .calculator-type-switch {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .calculator-type-switch label {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border: 1px solid var(--line);
    border-radius: 2px;
    cursor: pointer;
    font-size: 15px;
    transition:
      border-color 0.3s var(--ease),
      background-color 0.3s var(--ease);
  }

  .calculator-type-switch label:has(input:checked) {
    border-color: var(--ink);
    background: var(--paper-deep);
  }

  .calculator-type-switch input {
    accent-color: var(--moss);
    width: 15px;
    height: 15px;
  }

  .calculator-area__heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .calculator-area__heading label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--moss);
  }

  .calculator-area__heading output {
    font-family: var(--display);
    font-size: clamp(26px, 3.4vw, 34px);
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .calculator-area__heading output small {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 400;
    color: var(--ink-soft);
    letter-spacing: 0.04em;
  }

  .calculator-area__slider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 2px;
    background: linear-gradient(
      to right,
      var(--ink) 0%,
      var(--ink) var(--range-progress, 0%),
      var(--stone) var(--range-progress, 0%),
      var(--stone) 100%
    );
    outline: none;
    cursor: pointer;
  }

  .calculator-area__slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--paper);
    border: 1.5px solid var(--ink);
    transition: transform 0.2s var(--ease);
  }

  .calculator-area__slider::-webkit-slider-thumb:hover {
    transform: scale(1.12);
  }

  .calculator-area__slider::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--paper);
    border: 1.5px solid var(--ink);
  }

  .calculator-area__range {
    display: flex;
    justify-content: space-between;
    margin-top: 12px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
  }

  .calculator-area__helper {
    margin: 14px 0 0;
    font-size: 12px;
    color: var(--ink-soft);
  }

  .calculator-area__input {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-top: 22px;
    padding-top: 22px;
    border-top: 1px solid var(--line);
  }

  .calculator-area__input > label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .calculator-area__input-field {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 10px 14px;
    border: 1px solid var(--ink);
    border-radius: 2px;
    background: var(--paper);
    transition: border-color 0.2s var(--ease);
  }

  .calculator-area__input-field:focus-within {
    border-color: var(--moss);
  }

  .calculator-area__number {
    width: 84px;
    border: 0;
    padding: 0;
    margin: 0;
    background: transparent;
    font-family: var(--serif);
    font-size: 20px;
    line-height: 1;
    color: var(--ink);
    text-align: right;
    -moz-appearance: textfield;
  }

  .calculator-area__number:focus {
    outline: none;
  }

  .calculator-area__number::-webkit-outer-spin-button,
  .calculator-area__number::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .calculator-area__unit {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
  }

  .calculator-removal {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 26px;
    cursor: pointer;
  }

  .calculator-removal input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .calculator-removal__box {
    width: 18px;
    height: 18px;
    border: 1px solid var(--ink);
    border-radius: 2px;
    flex: none;
    position: relative;
    transition: background-color 0.25s var(--ease);
  }

  .calculator-removal input:checked + .calculator-removal__box {
    background: var(--ink);
  }

  .calculator-removal input:checked + .calculator-removal__box::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 1px;
    width: 5px;
    height: 10px;
    border: solid var(--paper);
    border-width: 0 1.5px 1.5px 0;
    transform: rotate(45deg);
  }

  .calculator-removal strong {
    font-weight: 500;
    font-size: 14px;
  }

  .calculator-removal small {
    display: block;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.03em;
    color: var(--ink-soft);
  }

  .price-calculator__summary {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(20px, 4vw, 56px);
    padding: clamp(24px, 3vw, 32px) 0 clamp(40px, 5vw, 56px);
  }

  .price-calculator__summary > div {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .price-calculator__summary span {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--moss);
  }

  .price-calculator__summary strong {
    font-family: var(--display);
    font-size: 20px;
    font-weight: 500;
  }

  /* package cards (rendered dynamically → :global) */
  .calculator-packages {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(16px, 2vw, 24px);
  }

  .calculator-packages :global(.calculator-package) {
    display: flex;
    flex-direction: column;
    padding: clamp(24px, 2.4vw, 34px);
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 3px;
    position: relative;
  }

  .calculator-packages :global(.calculator-package--featured) {
    border-color: var(--ink);
    background: var(--paper-deep);
  }

  .calculator-packages :global(.calculator-package__badge) {
    position: absolute;
    top: 18px;
    right: 18px;
    margin: 0;
    font-family: var(--mono);
    font-size: 8px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--moss);
  }

  .calculator-packages :global(.calculator-package__top) {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 18px;
  }

  .calculator-packages :global(.calculator-package__number) {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--moss);
    letter-spacing: 0.05em;
  }

  .calculator-packages :global(.calculator-package__english) {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .calculator-packages :global(.calculator-package h2) {
    margin: 0 0 10px;
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(20px, 2vw, 25px);
    letter-spacing: -0.01em;
  }

  .calculator-packages :global(.calculator-package__description) {
    margin: 0 0 22px;
    font-size: 13.5px;
    line-height: 1.7;
    color: var(--ink-soft);
    flex: 1;
  }

  .calculator-packages :global(.calculator-package__rate) {
    margin-bottom: 14px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .calculator-packages :global(.calculator-package__rate small) {
    display: block;
    margin-top: 6px;
    font-size: 9px;
    letter-spacing: 0.06em;
    color: var(--moss);
  }

  .calculator-packages :global(.calculator-package__estimate) {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 24px;
  }

  .calculator-packages :global(.calculator-package__estimate span) {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--moss);
  }

  .calculator-packages :global(.calculator-package__estimate strong) {
    font-family: var(--display);
    font-size: clamp(24px, 2.6vw, 30px);
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .calculator-packages :global(.calculator-package__cta) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 18px;
    border: 1px solid var(--ink);
    border-radius: 2px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition:
      background-color 0.3s var(--ease),
      color 0.3s var(--ease);
  }

  .calculator-packages :global(.calculator-package__cta:hover) {
    background: var(--ink);
    color: var(--paper);
  }

  .price-calculator__note {
    display: flex;
    gap: 16px;
    margin-top: clamp(40px, 5vw, 60px);
    padding-top: 28px;
    border-top: 1px solid var(--line);
    font-size: 12.5px;
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .price-calculator__note span {
    flex: none;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--moss);
    padding-top: 2px;
  }

  @media (max-width: 880px) {
    .price-calculator__controls {
      grid-template-columns: 1fr;
    }

    .calculator-packages {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  interface BrowserPriceRange {
    min: number;
    max: number;
  }

  interface BrowserPackage {
      id: 'essential' | 'signature' | 'elevated';
      label: string;
      enLabel: string;
      englishLabel: string;
      description: string;
      enDescription: string;
      price: BrowserPriceRange;
      materialsIncluded: boolean;
      featured?: boolean;
    }

  interface BrowserFlooringType {
    label: string;
    enLabel: string;
    minimumCharge: number;
    packages: BrowserPackage[];
  }

  interface BrowserCalculatorConfig {
    minArea: number;
    maxArea: number;
    step: number;
    defaultArea: number;
    removalRate: number;
    whatsappNumber: string;
  }

  interface BrowserUi {
    summaryType: string;
    summaryMinimum: string;
    packageRate: string;
    packageEstimate: string;
    packageCta: string;
    waGreeting: string;
    waArea: string;
    waPackage: string;
    waRemovalYes: string;
    waRemovalNo: string;
    waEstimate: string;
    waClosing: string;
  }

  const calculator = document.querySelector<HTMLElement>('[data-price-calculator]');

  if (calculator) {
    const pricing = JSON.parse(calculator.dataset.pricing ?? '{}') as Record<
      'spc' | 'outdoor',
      BrowserFlooringType
    >;
    const config = JSON.parse(calculator.dataset.config ?? '{}') as BrowserCalculatorConfig;
    const lang = calculator.dataset.lang === 'en' ? 'en' : 'zh-HK';
    const isEn = lang === 'en';

    const ui: Record<'zh-HK' | 'en', BrowserUi> = {
      'zh-HK': {
        summaryType: '目前選擇',
        summaryMinimum: '最低工程費',
        packageRate: '材料與安裝全包',
    packageRateExcluded: '只含安裝',
    materialNote: '不含材料',
        packageEstimate: '初步預算範圍',
        packageCta: '選擇此方案',
        waGreeting: '你好，想查詢初步地板報價。',
        waArea: '預計面積',
        waPackage: '方案',
        waRemovalYes: '需要拆除舊地板',
        waRemovalNo: '不需要拆除舊地板',
        waEstimate: '網站初步預算',
        waClosing: '請問可以安排進一步查詢或現場勘察嗎？',
      },
      en: {
        summaryType: 'Currently selected',
        summaryMinimum: 'Minimum project fee',
        packageRate: 'Material & installation included',
    packageRateExcluded: 'Installation only',
    materialNote: 'Materials not included',
        packageEstimate: 'Indicative estimate',
        packageCta: 'Choose this package',
        waGreeting: 'Hello, I would like a preliminary flooring quote.',
        waArea: 'Estimated area',
        waPackage: 'Package',
        waRemovalYes: 'Removal of existing flooring needed',
        waRemovalNo: 'No removal needed',
        waEstimate: 'Website indicative estimate',
        waClosing: 'Could we arrange a follow-up or site visit?',
      },
    };
    const t = ui[lang];

    const slider = calculator.querySelector<HTMLInputElement>('#area-slider');
    const typeInputs = calculator.querySelectorAll<HTMLInputElement>('input[name="flooring-type"]');
    const removalToggle = calculator.querySelector<HTMLInputElement>('[data-removal-toggle]');
    const areaOutput = calculator.querySelector<HTMLOutputElement>('[data-area-output]');
    const areaInput = calculator.querySelector<HTMLInputElement>('[data-area-input]');
    const typeOutput = calculator.querySelector<HTMLElement>('[data-summary-type]');
    const minimumOutput = calculator.querySelector<HTMLElement>('[data-summary-minimum]');
    const removalSummary = calculator.querySelector<HTMLElement>('[data-removal-summary]');
    const removalAmount = calculator.querySelector<HTMLElement>('[data-removal-amount]');
    const packagesContainer = calculator.querySelector<HTMLElement>('[data-package-list]');

    const currency = new Intl.NumberFormat('en-HK', {
      style: 'currency',
      currency: 'HKD',
      maximumFractionDigits: 0,
    });

    const getSelectedType = () => {
      const selected = calculator.querySelector<HTMLInputElement>('input[name="flooring-type"]:checked');
      return selected?.value === 'outdoor' ? 'outdoor' : 'spc';
    };

    const getArea = () => Number(slider?.value ?? config.defaultArea);
    const hasRemoval = () => Boolean(removalToggle?.checked);

    const calculateRange = (area: number, price: BrowserPriceRange, minimumCharge: number) => {
      const removalCost = hasRemoval() ? area * config.removalRate : 0;

      return {
        min: Math.max(area * price.min, minimumCharge) + removalCost,
        max: Math.max(area * price.max, minimumCharge) + removalCost,
        removalCost,
      };
    };

    const packageNumber = (id: BrowserPackage['id']) => {
      if (id === 'essential') return '01';
      if (id === 'signature') return '02';
      return '03';
    };

    const createPackageCard = (
      packageItem: BrowserPackage,
      flooring: BrowserFlooringType,
      area: number,
    ) => {
      const estimate = calculateRange(area, packageItem.price, flooring.minimumCharge);
      const name = isEn ? packageItem.enLabel : packageItem.label;
      const description = isEn ? packageItem.enDescription : packageItem.description;
      const featuredClass = packageItem.featured ? ' calculator-package--featured' : '';
      const badge = packageItem.featured
        ? `<p class="calculator-package__badge">${t.packageCta ? 'Most chosen' : 'Most chosen'}</p>`
        : '';

      return `
        <article class="calculator-package${featuredClass}" data-package="${packageItem.id}">
          ${badge}
          <div class="calculator-package__top">
            <span class="calculator-package__number">${packageNumber(packageItem.id)}</span>
            <span class="calculator-package__english">${packageItem.englishLabel}</span>
          </div>
          <h2>${name}</h2>
          <p class="calculator-package__description">${description}</p>
          <div class="calculator-package__rate">
            <span>${packageItem.materialsIncluded ? t.packageRate : t.packageRateExcluded}</span>
            ${packageItem.materialsIncluded ? '' : `<small>${t.materialNote}</small>`}
          </div>
          <div class="calculator-package__estimate">
            <span>${t.packageEstimate}</span>
            <strong>${currency.format(estimate.min)} – ${currency.format(estimate.max)}</strong>
          </div>
          <a
            class="calculator-package__cta"
            href="https://wa.me/${config.whatsappNumber}"
            target="_blank"
            rel="noopener noreferrer"
            data-whatsapp="${packageItem.id}"
          >
            ${t.packageCta} <span>↗</span>
          </a>
        </article>
      `;
    };

    const refreshWhatsAppLinks = (
      flooring: BrowserFlooringType,
      area: number,
    ) => {
      calculator.querySelectorAll<HTMLAnchorElement>('[data-whatsapp]').forEach((link) => {
        const selectedPackage = flooring.packages.find(
          (packageItem) => packageItem.id === link.dataset.whatsapp,
        );

        if (!selectedPackage) return;

        const estimate = calculateRange(area, selectedPackage.price, flooring.minimumCharge);
        const removalText = hasRemoval() ? t.waRemovalYes : t.waRemovalNo;
        const name = isEn ? selectedPackage.enLabel : selectedPackage.label;

        const message = [
          t.waGreeting,
          `${flooring.enLabel}: ${name}`,
          `${t.waArea}: ${area.toLocaleString()} sq ft`,
          `${t.waPackage}: ${name} (${selectedPackage.englishLabel})`,
          `${removalText}`,
          `${t.waEstimate}: ${currency.format(estimate.min)} – ${currency.format(estimate.max)}`,
          t.waClosing,
        ].join('\n');

        link.href = `https://wa.me/${config.whatsappNumber}?text=${encodeURIComponent(message)}`;
      });
    };

    const updateSliderFill = (area: number) => {
      if (!slider) return;

      const percentage = ((area - config.minArea) / (config.maxArea - config.minArea)) * 100;
      slider.style.setProperty('--range-progress', `${percentage}%`);
    };

    const render = () => {
      const selectedType = getSelectedType();
      const flooring = pricing[selectedType];
      const area = getArea();
      const removalCost = hasRemoval() ? area * config.removalRate : 0;
      const name = isEn ? flooring.enLabel : flooring.label;

      if (areaOutput) {
        areaOutput.innerHTML = `${area.toLocaleString()} <small>sq ft</small>`;
      }

      if (typeOutput) typeOutput.textContent = name;
      if (minimumOutput) minimumOutput.textContent = currency.format(flooring.minimumCharge);

      if (removalSummary) removalSummary.hidden = !hasRemoval();
      if (removalAmount) removalAmount.textContent = currency.format(removalCost);

      if (packagesContainer) {
        packagesContainer.innerHTML = flooring.packages
          .map((packageItem) => createPackageCard(packageItem, flooring, area))
          .join('');
      }

      updateSliderFill(area);

      if (areaInput && document.activeElement !== areaInput) {
        areaInput.value = String(area);
      }

      refreshWhatsAppLinks(flooring, area);
    };

    slider?.addEventListener('input', render);
    removalToggle?.addEventListener('change', render);
    typeInputs.forEach((input) => input.addEventListener('change', render));

    areaInput?.addEventListener('input', () => {
      if (!slider) return;

      const raw = Number(areaInput.value);
      let next = Number.isFinite(raw) ? raw : config.minArea;
      next = Math.min(config.maxArea, Math.max(config.minArea, next));

      slider.value = String(next);
      render();
    });

    render();
  }
</script>
