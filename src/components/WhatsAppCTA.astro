---
interface Props {
  label: string;
  secondary?: boolean;
}

const { label, secondary = false } = Astro.props;
---

<a
  class:list={['button', secondary && 'button--light']}
  href="https://wa.me/85295715155"
  target="_blank"
  rel="noopener noreferrer"
>
  <span>{label}</span>
  <span class="button__arrow" aria-hidden="true">↗</span>
</a>
