---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const projects = [
  {
    number: '01',
    category: 'Private Residence',
    title: '讓自然木紋，成為生活的背景。',
    detail: 'SPC Flooring · Hong Kong',
    image: '/images/projects/project-residential-01.jpg',
    layout: 'editorial-project--wide',
  },
  {
    number: '02',
    category: 'Commercial Space',
    title: '留給日常，一個安靜的基礎。',
    detail: 'Flooring Construction · Hong Kong',
    image: '/images/projects/project-commercial-01.jpg',
    layout: 'editorial-project--portrait',
  },
  {
    number: '03',
    category: 'Outdoor Terrace',
    title: '延伸到光、風與時間之中。',
    detail: 'Outdoor Flooring · Hong Kong',
    image: '/images/projects/project-outdoor-01.jpg',
    layout: 'editorial-project--wide editorial-project--offset',
  },
];

const process = [
  {
    number: '01',
    title: '對話',
    description: '由你的空間、相片與初步想法開始。',
  },
  {
    number: '02',
    title: '理解',
    description: '走進現場，看見基層、光線與使用方式。',
  },
  {
    number: '03',
    title: '選擇',
    description: '在材質、比例與耐用之間，找到合適的答案。',
  },
  {
    number: '04',
    title: '完成',
    description: '以細緻收口，讓地面成為空間的一部分。',
  },
];
---

<BaseLayout
  title="Jupiter’s Design Limited｜香港地板工程"
  description="Jupiter’s Design Limited 專注香港住宅及商業空間的 SPC 地板、戶外地板及地面工程。以材料、細節與安靜的施工節奏，為空間建立長久基礎。"
  lang="zh-HK"
  canonicalPath="/"
>
  <Header lang="zh-HK" />

  <main id="top">
    <section class="editorial-hero">
      <div class="editorial-hero__image" aria-hidden="true"></div>
      <div class="editorial-hero__veil" aria-hidden="true"></div>

      <div class="editorial-hero__content editorial-shell">
        <p class="editorial-kicker">Jupiter’s Design Limited · Hong Kong</p>

        <h1>
          地面，讓空間<br />
          <em>安靜下來。</em>
        </h1>

        <div class="editorial-hero__footer">
          <p>SPC Flooring · Outdoor Flooring · Construction</p>
          <a href="#approach">向下探索 <span>↓</span></a>
        </div>
      </div>
    </section>

    <section id="approach" class="editorial-manifesto">
      <div class="editorial-shell">
        <p class="editorial-kicker" data-reveal>01 · Our Approach</p>

        <div class="editorial-manifesto__statement" data-reveal>
          <p>
            好的地板，<br />
            不爭取注意。<br />
            它讓每一個日常，<br />
            <em>自然地發生。</em>
          </p>
        </div>

        <div class="editorial-manifesto__note" data-reveal>
          <p>
            Jupiter’s Design Limited 專注於 SPC 地板、戶外地板及相關地面工程。
            我們從現場開始，理解材料如何陪伴光線、步伐與時間。
          </p>
          <a class="editorial-text-link" href="#contact">開始一段對話 <span>↗</span></a>
        </div>
      </div>
    </section>

    <section id="services" class="editorial-practices">
      <article class="editorial-practice editorial-practice--dark">
        <div class="editorial-shell editorial-practice__inner">
          <div class="editorial-practice__index" data-reveal>
            <span>02</span>
            <span>Practice</span>
          </div>

          <div class="editorial-practice__copy" data-reveal>
            <p class="editorial-kicker">SPC Flooring</p>
            <h2>
              穩定，不代表<br />
              <em>失去溫度。</em>
            </h2>
            <p class="editorial-practice__description">
              為每天被使用的室內空間，選擇兼具耐用、穩定與自然觸感的地面。
            </p>
          </div>

          <a
            class="editorial-arrow-link"
            href="https://wa.me/85295715155"
            target="_blank"
            rel="noopener noreferrer"
            data-reveal
          >
            WhatsApp 查詢 <span>↗</span>
          </a>
        </div>

        <div class="editorial-practice__image editorial-practice__image--spc" aria-hidden="true"></div>
      </article>

      <article class="editorial-practice editorial-practice--light">
        <div class="editorial-practice__image editorial-practice__image--outdoor" aria-hidden="true"></div>

        <div class="editorial-shell editorial-practice__inner">
          <div class="editorial-practice__index" data-reveal>
            <span>03</span>
            <span>Practice</span>
          </div>

          <div class="editorial-practice__copy" data-reveal>
            <p class="editorial-kicker">Outdoor Flooring</p>
            <h2>
              把空間，<br />
              <em>交還給光與風。</em>
            </h2>
            <p class="editorial-practice__description">
              由露台、天台至戶外平台，讓材質回應日照、排水與季節的變化。
            </p>
          </div>

          <a
            class="editorial-arrow-link"
            href="https://wa.me/85295715155"
            target="_blank"
            rel="noopener noreferrer"
            data-reveal
          >
            WhatsApp 查詢 <span>↗</span>
          </a>
        </div>
      </article>

      <article class="editorial-practice editorial-practice--earth">
        <div class="editorial-shell editorial-practice__inner">
          <div class="editorial-practice__index" data-reveal>
            <span>04</span>
            <span>Practice</span>
          </div>

          <div class="editorial-practice__copy" data-reveal>
            <p class="editorial-kicker">Flooring Construction</p>
            <h2>
              看不見的地方，<br />
              <em>也值得做好。</em>
            </h2>
            <p class="editorial-practice__description">
              由基層處理、材料比例到最後收口，讓工程有安靜而可靠的完成度。
            </p>
          </div>

          <a
            class="editorial-arrow-link"
            href="https://wa.me/85295715155"
            target="_blank"
            rel="noopener noreferrer"
            data-reveal
          >
            WhatsApp 查詢 <span>↗</span>
          </a>
        </div>

        <div class="editorial-practice__image editorial-practice__image--construction" aria-hidden="true"></div>
      </article>
    </section>

    <section id="projects" class="editorial-projects">
      <div class="editorial-shell">
        <div class="editorial-projects__intro">
          <p class="editorial-kicker" data-reveal>05 · Selected Spaces</p>
          <h2 data-reveal>
            空間的質感，<br />
            <em>由腳下開始。</em>
          </h2>
        </div>

        <div class="editorial-projects__list">
          {projects.map((project) => (
            <article class:list={['editorial-project', project.layout]} data-reveal>
              <div class="editorial-project__image">
                <img src={project.image} alt={`${project.title}｜${project.category}`} loading="lazy" />
              </div>

              <div class="editorial-project__meta">
                <span>{project.number} · {project.category}</span>
                <span>{project.detail}</span>
              </div>

              <h3>{project.title}</h3>
            </article>
          ))}
        </div>

        <a
          class="editorial-text-link editorial-projects__link"
          href="https://wa.me/85295715155"
          target="_blank"
          rel="noopener noreferrer"
          data-reveal
        >
          與我們討論你的空間 <span>↗</span>
        </a>
      </div>
    </section>

    <section class="editorial-material">
      <div class="editorial-material__image" aria-hidden="true"></div>
      <div class="editorial-shell editorial-material__caption">
        <span>Material · Light · Detail</span>
        <span>Jupiter’s Design Limited</span>
      </div>
    </section>

    <section class="editorial-process">
      <div class="editorial-shell">
        <div class="editorial-process__intro">
          <p class="editorial-kicker" data-reveal>06 · A Considered Process</p>
          <h2 data-reveal>
            從一個想法，<br />
            <em>到一個完成的地面。</em>
          </h2>
        </div>

        <ol class="editorial-process__list">
          {process.map((item) => (
            <li data-reveal>
              <span class="editorial-process__number">{item.number}</span>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section id="contact" class="editorial-contact">
      <div class="editorial-shell editorial-contact__inner">
        <p class="editorial-kicker" data-reveal>07 · Get In Touch</p>

        <h2 data-reveal>
          讓我們從你的空間開始。<br />
          <em>慢慢把它做好。</em>
        </h2>

        <a
          class="editorial-contact__cta"
          href="https://wa.me/85295715155"
          target="_blank"
          rel="noopener noreferrer"
          data-reveal
        >
          <span>開始一段對話</span>
          <span>↗</span>
        </a>

        <div class="editorial-contact__details" data-reveal>
          <a href="https://wa.me/85295715155" target="_blank" rel="noopener noreferrer">
            <span>WhatsApp</span>
            <strong>+852 9571 5155</strong>
          </a>
          <a href="https://www.instagram.com/jupitersdesign/" target="_blank" rel="noopener noreferrer">
            <span>Instagram</span>
            <strong>@jupitersdesign</strong>
          </a>
          <a href="mailto:info@jupitersdesign.com">
            <span>Email</span>
            <strong>info@jupitersdesign.com</strong>
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="editorial-footer">
    <div class="editorial-shell editorial-footer__inner">
      <p>© {new Date().getFullYear()} Jupiter’s Design Limited</p>
      <a href="#top">Back to top ↑</a>
      <p>Hong Kong</p>
    </div>
  </footer>
</BaseLayout>