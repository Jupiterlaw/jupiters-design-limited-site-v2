---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import WhatsAppCTA from '../../components/WhatsAppCTA.astro';

const projects = [
  {
    number: '01',
    type: 'Residential',
    title: 'Natural grain, quietly grounded',
    location: 'Private Residence · Hong Kong',
    image: '/images/projects/project-residential-01.jpg',
    className: 'project-card--large',
  },
  {
    number: '02',
    type: 'Commercial',
    title: 'Room to work, space to breathe',
    location: 'Commercial Space · Hong Kong',
    image: '/images/projects/project-commercial-01.jpg',
    className: 'project-card--small',
  },
  {
    number: '03',
    type: 'Outdoor',
    title: 'Extended into light and air',
    location: 'Outdoor Terrace · Hong Kong',
    image: '/images/projects/project-outdoor-01.jpg',
    className: 'project-card--wide',
  },
];

const faqs = [
  {
    question: 'Is SPC flooring suitable for Hong Kong’s humid climate?',
    answer:
      'Yes. SPC flooring is stable, moisture-resistant and easy to maintain. We assess your subfloor condition, humidity and lifestyle before recommending a suitable approach.',
  },
  {
    question: 'Can you arrange a site visit and quotation?',
    answer:
      'Yes. Send us photos, a floor plan or approximate dimensions on WhatsApp. We will understand your needs first, then arrange a suitable site inspection and quotation process.',
  },
  {
    question: 'How long does a flooring project take?',
    answer:
      'Timing depends on the project area, subfloor condition, selected materials and site coordination. We will outline the expected schedule once the scope is confirmed.',
  },
  {
    question: 'Where can outdoor flooring be installed?',
    answer:
      'Outdoor flooring can be used for terraces, rooftops, podiums and gardens. We consider sunlight, drainage, frequency of use and the surrounding conditions.',
  },
];
---

<BaseLayout
  title="Jupiter’s Design Limited | Flooring Specialists in Hong Kong"
  description="Jupiter’s Design Limited delivers SPC flooring, outdoor flooring and flooring construction for thoughtfully designed residential and commercial spaces in Hong Kong."
  lang="en"
  canonicalPath="/en/"
>
  <Header lang="en" />

  <main id="top">
    <section class="hero">
      <div class="hero__image" role="img" aria-label="Jupiter’s Design flooring project">
        <div class="hero__overlay"></div>
      </div>

      <div class="hero__content page-shell">
        <p class="eyebrow hero__eyebrow">Jupiter’s Design Limited · Hong Kong</p>

        <h1>
          Grounded in material.<br />
          <em>Defined by detail.</em>
        </h1>

        <div class="hero__bottom">
          <p>Flooring is never just a surface.<br />It shapes the pace, light and quiet of a space.</p>
          <WhatsAppCTA label="Start your flooring project" />
        </div>
      </div>

      <a class="hero__scroll" href="#about" aria-label="Scroll to about">
        <span>Scroll to explore</span>
        <i></i>
      </a>
    </section>

    <section id="about" class="intro section-space">
      <div class="page-shell intro__grid">
        <div data-reveal>
          <p class="eyebrow">01 · Our Approach</p>
        </div>

        <div class="intro__copy" data-reveal>
          <p class="display-copy">
            Good flooring does not ask<br />
            to be noticed. It lets material,<br />
            proportion and detail shape<br />
            a space for everyday life.
          </p>

          <div class="intro__details">
            <p>
              Jupiter’s Design Limited specialises in SPC flooring, outdoor flooring
              and flooring construction for thoughtfully considered residential and commercial spaces in Hong Kong.
            </p>

            <a class="text-link" href="#contact">
              Meet Jupiter’s Design <span>↗</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="services" class="services section-space section-space--dark">
      <div class="page-shell">
        <div class="section-heading" data-reveal>
          <p class="eyebrow">02 · What We Do</p>
          <h2>Start with material.<br /><em>Give every step a reason.</em></h2>
        </div>

        <div class="services__list">
          <article class="service-item" data-reveal>
            <span class="service-item__number">01</span>
            <div>
              <h3>SPC Flooring</h3>
              <p>Stable, durable and naturally composed flooring solutions for residential and commercial interiors.</p>
            </div>
            <span class="service-item__arrow">↗</span>
          </article>

          <article class="service-item" data-reveal>
            <span class="service-item__number">02</span>
            <div>
              <h3>Outdoor Flooring</h3>
              <p>Thoughtful solutions for terraces, rooftops and exterior spaces, considering sun, drainage and durability.</p>
            </div>
            <span class="service-item__arrow">↗</span>
          </article>

          <article class="service-item" data-reveal>
            <span class="service-item__number">03</span>
            <div>
              <h3>Flooring Construction</h3>
              <p>From site assessment and subfloor preparation to material selection and finishing details, managed with clarity.</p>
            </div>
            <span class="service-item__arrow">↗</span>
          </article>
        </div>
      </div>
    </section>

    <section id="projects" class="projects section-space">
      <div class="page-shell">
        <div class="projects__top" data-reveal>
          <div class="section-heading">
            <p class="eyebrow">03 · Selected Works</p>
            <h2>Spaces become complete<br /><em>when they are lived in.</em></h2>
          </div>

          <p>Residential, commercial and outdoor spaces.<br />Every project begins by understanding its setting.</p>
        </div>

        <div class="projects__grid">
          {projects.map((project) => (
            <article class:list={['project-card', project.className]} data-reveal>
              <div class="project-card__image">
                <img src={project.image} alt={`${project.title} | ${project.type}`} loading="lazy" />
              </div>

              <div class="project-card__meta">
                <span>{project.number} · {project.type}</span>
                <span>{project.location}</span>
              </div>

              <h3>{project.title}</h3>
            </article>
          ))}
        </div>

        <div class="projects__footer" data-reveal>
          <p>Your space can begin with a better foundation.</p>
          <WhatsAppCTA label="Discuss your project" secondary={true} />
        </div>
      </div>
    </section>

    <section class="image-break" aria-label="Flooring material detail">
      <div class="image-break__image"></div>
      <div class="image-break__caption page-shell">
        <span>Material · Light · Detail</span>
        <span>Jupiter’s Design Limited</span>
      </div>
    </section>

    <section id="why-us" class="why-us section-space">
      <div class="page-shell why-us__grid">
        <div class="section-heading" data-reveal>
          <p class="eyebrow">04 · Why Jupiter’s</p>
          <h2>Beyond the build,<br /><em>we care how it feels.</em></h2>
        </div>

        <div class="why-us__list">
          <article data-reveal>
            <span>01</span>
            <h3>Site-first thinking</h3>
            <p>We begin with your subfloor, natural light, movement and daily use, not a one-size-fits-all solution.</p>
          </article>

          <article data-reveal>
            <span>02</span>
            <h3>Finishing matters</h3>
            <p>The meeting points between flooring, walls, doors, cabinetry and materials define whether a space feels resolved.</p>
          </article>

          <article data-reveal>
            <span>03</span>
            <h3>Clear communication</h3>
            <p>From enquiry to handover, we keep the process considered, clear and responsive at every important stage.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="process" class="process section-space section-space--sand">
      <div class="page-shell">
        <div class="section-heading" data-reveal>
          <p class="eyebrow">05 · Our Process</p>
          <h2>From the first conversation<br /><em>to every final detail.</em></h2>
        </div>

        <ol class="process__list">
          <li data-reveal>
            <span>01</span>
            <h3>Initial conversation</h3>
            <p>Share photos, a floor plan or your initial requirements on WhatsApp so we can understand your space.</p>
          </li>

          <li data-reveal>
            <span>02</span>
            <h3>Site assessment</h3>
            <p>We assess the subfloor, dimensions, moisture conditions and practical site considerations.</p>
          </li>

          <li data-reveal>
            <span>03</span>
            <h3>Material and quotation</h3>
            <p>We propose materials and an installation approach suited to your use and the character of the space.</p>
          </li>

          <li data-reveal>
            <span>04</span>
            <h3>Installation and handover</h3>
            <p>We complete the work to the agreed plan, with careful attention to finishing and the experience of the final space.</p>
          </li>
        </ol>
      </div>
    </section>

    <section id="faq" class="faq section-space">
      <div class="page-shell faq__grid">
        <div class="section-heading" data-reveal>
          <p class="eyebrow">06 · FAQ</p>
          <h2>What you need to know,<br /><em>answered clearly.</em></h2>
        </div>

        <div class="faq__list" data-reveal>
          {faqs.map((faq, index) => (
            <details class="faq-item" open={index === 0}>
              <summary>
                <span>{faq.question}</span>
                <span class="faq-item__icon">+</span>
              </summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="contact">
      <div class="page-shell contact__inner">
        <p class="eyebrow">07 · Get In Touch</p>

        <h2 data-reveal>
          Let's begin with your space.<br />
          <em>Then make it right.</em>
        </h2>

        <div class="contact__cta" data-reveal>
          <WhatsAppCTA label="Contact us on WhatsApp" />
          <p>Send us photos, a floor plan or your initial idea.<br />We will begin by understanding the space and what it needs.</p>
        </div>

        <div class="contact__details">
          <a href="https://wa.me/85295715155" target="_blank" rel="noopener noreferrer">
            <span>WhatsApp</span>
            <strong>+852 9571 5155</strong>
          </a>

          <a
            href="https://www.instagram.com/jupitersdesign/"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span>Instagram</span>
            <strong>@jupitersdesign</strong>
          </a>

          <a href="mailto:info@jupitersdesign.com">
            <span>Email</span>
            <strong>info@jupitersdesign.com</strong>
          </a>

          <a href="https://www.jupitersdesign.com">
            <span>Website</span>
            <strong>jupitersdesign.com</strong>
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="page-shell site-footer__inner">
      <p>© {new Date().getFullYear()} Jupiter’s Design Limited</p>
      <a href="#top">Back to top ↑</a>
      <p>Hong Kong</p>
    </div>
  </footer>
</BaseLayout>
