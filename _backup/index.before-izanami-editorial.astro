---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';

const projects = [
  {
    number: '01',
    type: '住宅空間',
    title: '自然木紋，安靜落地',
    location: 'Private Residence · Hong Kong',
    image: '/images/projects/project-residential-01.jpg',
    className: 'project-card--large',
  },
  {
    number: '02',
    type: '商業空間',
    title: '為日常工作留下餘裕',
    location: 'Commercial Space · Hong Kong',
    image: '/images/projects/project-commercial-01.jpg',
    className: 'project-card--small',
  },
  {
    number: '03',
    type: '戶外空間',
    title: '延伸至光與風之中',
    location: 'Outdoor Terrace · Hong Kong',
    image: '/images/projects/project-outdoor-01.jpg',
    className: 'project-card--wide',
  },
];

const faqs = [
  {
    question: 'SPC 地板適合香港的潮濕天氣嗎？',
    answer:
      '適合。SPC 地板具備穩定、防潮及易於日常打理的特性；我們會根據現場濕度、基層狀況及使用習慣，提供合適的施工建議。',
  },
  {
    question: '可以安排上門度尺及報價嗎？',
    answer:
      '可以。你可透過 WhatsApp 傳送單位相片、平面圖或基本尺寸，我們會先了解需要，再安排合適的現場勘察及報價流程。',
  },
  {
    question: '一般地板工程需要多久？',
    answer:
      '施工時間視乎面積、基層狀況、材料及現場配合而定。我們會在確認工程範圍後，提供清楚的施工安排與預計時間。',
  },
  {
    question: '戶外地板可用於哪些位置？',
    answer:
      '戶外地板可應用於露台、天台、平台及庭園等位置。我們會按日照、排水、使用頻率及現場環境建議合適方案。',
  },
];
---

<BaseLayout
  title="Jupiter’s Design Limited｜香港地板工程 · SPC 地板 · 戶外地板"
  description="Jupiter’s Design Limited 專注香港住宅及商業空間的 SPC 地板、戶外地板及相關地面工程，以細節與材料質感定義空間。"
  lang="zh-HK"
  canonicalPath="/"
>
  <Header lang="zh" />

  <main id="top">
    <section class="hero">
      <div class="hero__image" role="img" aria-label="Jupiter’s Design 地板工程作品">
        <div class="hero__overlay"></div>
      </div>

      <div class="hero__content page-shell">
        <p class="eyebrow hero__eyebrow">Jupiter’s Design Limited · Hong Kong</p>

        <h1>
          為空間，鋪設<br />
          <em>恰到好處的質感。</em>
        </h1>

        <div class="hero__bottom">
          <p>地板不只是表面。<br />它決定一個空間的步伐、光線與安靜感。</p>
          <WhatsAppCTA label="開始你的地板計劃" />
        </div>
      </div>

      <a class="hero__scroll" href="#about" aria-label="捲動至關於我們">
        <span>Scroll to explore</span>
        <i></i>
      </a>
    </section>

    <section id="about" class="intro section-space">
      <div class="page-shell intro__grid">
        <div data-reveal>
          <p class="eyebrow">01 · Our Approach</p>
        </div>

        <div class="intro__copy" data-reveal>
          <p class="display-copy">
            我們相信，好的地面不喧嘩。<br />
            它以材質、比例與細節，<br />
            讓空間自然地成為生活的一部分。
          </p>

          <div class="intro__details">
            <p>
              Jupiter’s Design Limited 專注於 SPC 地板、戶外地板及相關地面工程，
              為香港住宅與商業空間提供周全而克制的施工方案。
            </p>

            <a class="text-link" href="#contact">
              認識 Jupiter’s Design <span>↗</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="services" class="services section-space section-space--dark">
      <div class="page-shell">
        <div class="section-heading" data-reveal>
          <p class="eyebrow">02 · What We Do</p>
          <h2>從材質開始，<br /><em>讓每一步都有依據。</em></h2>
        </div>

        <div class="services__list">
          <article class="service-item" data-reveal>
            <span class="service-item__number">01</span>
            <div>
              <h3>SPC Flooring</h3>
              <p>
                兼顧穩定性、日常耐用度與自然觀感，為住宅及商業室內空間建立實用而細緻的地面基礎。
              </p>
            </div>
            <span class="service-item__arrow">↗</span>
          </article>

          <article class="service-item" data-reveal>
            <span class="service-item__number">02</span>
            <div>
              <h3>Outdoor Flooring</h3>
              <p>
                針對露台、天台與戶外平台的使用條件，考慮日照、排水與耐候性，延伸空間的生活感。
              </p>
            </div>
            <span class="service-item__arrow">↗</span>
          </article>

          <article class="service-item" data-reveal>
            <span class="service-item__number">03</span>
            <div>
              <h3>Flooring Construction</h3>
              <p>
                由現場勘察、基層處理、物料選擇至收口細節，讓地板工程有清晰節奏，也有可靠完成度。
              </p>
            </div>
            <span class="service-item__arrow">↗</span>
          </article>
        </div>
      </div>
    </section>

    <section id="projects" class="projects section-space">
      <div class="page-shell">
        <div class="projects__top" data-reveal>
          <div class="section-heading">
            <p class="eyebrow">03 · Selected Works</p>
            <h2>被日常使用的<br /><em>空間，才真正完整。</em></h2>
          </div>

          <p>住宅、商業與戶外空間。<br />每個工程都從現場條件開始理解。</p>
        </div>

        <div class="projects__grid">
          {projects.map((project) => (
            <article class:list={['project-card', project.className]} data-reveal>
              <div class="project-card__image">
                <img src={project.image} alt={`${project.title}｜${project.type}`} loading="lazy" />
              </div>

              <div class="project-card__meta">
                <span>{project.number} · {project.type}</span>
                <span>{project.location}</span>
              </div>

              <h3>{project.title}</h3>
            </article>
          ))}
        </div>

        <div class="projects__footer" data-reveal>
          <p>你的空間，也可以從一個更好的地面開始。</p>
          <WhatsAppCTA label="與我們討論你的項目" secondary={true} />
        </div>
      </div>
    </section>

    <section class="image-break" aria-label="地板材質細節">
      <div class="image-break__image"></div>
      <div class="image-break__caption page-shell">
        <span>Material · Light · Detail</span>
        <span>Jupiter’s Design Limited</span>
      </div>
    </section>

    <section id="why-us" class="why-us section-space">
      <div class="page-shell why-us__grid">
        <div class="section-heading" data-reveal>
          <p class="eyebrow">04 · Why Jupiter’s</p>
          <h2>工程之外，<br /><em>我們在意完成後的感受。</em></h2>
        </div>

        <div class="why-us__list">
          <article data-reveal>
            <span>01</span>
            <h3>以現場為先</h3>
            <p>不以單一方案套用每個空間，而是先了解基層、光線、動線與使用方式。</p>
          </article>

          <article data-reveal>
            <span>02</span>
            <h3>重視收口細節</h3>
            <p>地板與牆身、門口、櫃體及不同材質之間的交界，決定整體是否真正俐落。</p>
          </article>

          <article data-reveal>
            <span>03</span>
            <h3>清楚溝通節奏</h3>
            <p>由諮詢至交付，以清楚的施工安排與持續溝通，讓你掌握每一個重要決定。</p>
          </article>
        </div>
      </div>
    </section>

    <section id="process" class="process section-space section-space--sand">
      <div class="page-shell">
        <div class="section-heading" data-reveal>
          <p class="eyebrow">05 · Our Process</p>
          <h2>從第一次對話，<br /><em>到每一個落點。</em></h2>
        </div>

        <ol class="process__list">
          <li data-reveal>
            <span>01</span>
            <h3>初步了解</h3>
            <p>透過 WhatsApp 分享相片、平面圖或基本需求，讓我們先理解你的空間。</p>
          </li>

          <li data-reveal>
            <span>02</span>
            <h3>現場勘察</h3>
            <p>評估基層、尺寸、濕度及現場限制，確認適合的施工方向。</p>
          </li>

          <li data-reveal>
            <span>03</span>
            <h3>選材與報價</h3>
            <p>根據使用需求及空間氣質，提供材料與工程方案，並清楚列出報價範圍。</p>
          </li>

          <li data-reveal>
            <span>04</span>
            <h3>施工與交付</h3>
            <p>按已確認的安排進行施工，處理細節收口，完成可被長久使用的空間基礎。</p>
          </li>
        </ol>
      </div>
    </section>

    <section id="faq" class="faq section-space">
      <div class="page-shell faq__grid">
        <div class="section-heading" data-reveal>
          <p class="eyebrow">06 · FAQ</p>
          <h2>你想知道的，<br /><em>我們先回答。</em></h2>
        </div>

        <div class="faq__list" data-reveal>
          {faqs.map((faq, index) => (
            <details class="faq-item" open={index === 0}>
              <summary>
                <span>{faq.question}</span>
                <span class="faq-item__icon">+</span>
              </summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="contact">
      <div class="page-shell contact__inner">
        <p class="eyebrow">07 · Get In Touch</p>

        <h2 data-reveal>
          讓我們從你的空間開始。<br />
          <em>慢慢把它做好。</em>
        </h2>

        <div class="contact__cta" data-reveal>
          <WhatsAppCTA label="WhatsApp 聯絡我們" />
          <p>歡迎傳送相片、平面圖或你的初步想法。<br />我們會由空間與需要開始了解。</p>
        </div>

        <div class="contact__details">
          <a href="https://wa.me/85295715155" target="_blank" rel="noopener noreferrer">
            <span>WhatsApp</span>
            <strong>+852 9571 5155</strong>
          </a>

          <a
            href="https://www.instagram.com/jupitersdesign/"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span>Instagram</span>
            <strong>@jupitersdesign</strong>
          </a>

          <a href="mailto:info@jupitersdesign.com">
            <span>Email</span>
            <strong>info@jupitersdesign.com</strong>
          </a>

          <a href="https://www.jupitersdesign.com">
            <span>Website</span>
            <strong>jupitersdesign.com</strong>
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="page-shell site-footer__inner">
      <p>© {new Date().getFullYear()} Jupiter’s Design Limited</p>
      <a href="#top">Back to top ↑</a>
      <p>Hong Kong</p>
    </div>
  </footer>
</BaseLayout>
